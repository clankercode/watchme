{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watchme.local/schemas/provider-manifest.schema.json",
  "title": "WatchMe Agent/Provider Manifest",
  "description": "Declarative detection and capability metadata. A manifest cannot add arbitrary code or weaken compiled policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "manifest_version",
    "updated_at",
    "support_tier",
    "aliases",
    "process_matchers",
    "provider_resolution",
    "screen_rules",
    "deterministic_recoveries",
    "planner_recipes"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/slug" },
    "manifest_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "updated_at": { "type": "string", "format": "date-time" },
    "min_watchme_version": { "type": ["string", "null"], "maxLength": 64 },
    "description": { "type": ["string", "null"], "maxLength": 500 },
    "source_url": { "type": ["string", "null"], "format": "uri", "maxLength": 1000 },
    "support_tier": { "enum": ["structured", "deterministic_terminal", "planner_assisted", "observation_only", "disabled"] },
    "aliases": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/slug" }
    },
    "version_range": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "minimum": { "type": ["string", "null"], "maxLength": 64 },
        "maximum_exclusive": { "type": ["string", "null"], "maxLength": 64 },
        "unknown_version_policy": { "enum": ["observation_only", "disable", "allow_exact_rules"] }
      }
    },
    "process_matchers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "pattern", "weight"],
        "properties": {
          "kind": { "enum": ["executable_basename", "executable_realpath", "argv_literal", "argv_safe_regex", "environment_hint"] },
          "pattern": { "type": "string", "minLength": 1, "maxLength": 256 },
          "weight": { "type": "integer", "minimum": -100, "maximum": 100 },
          "case_sensitive": { "type": "boolean", "default": false }
        }
      }
    },
    "version_probe": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/command_spec" }
      ]
    },
    "provider_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["fixed", "argv", "environment", "config_metadata", "runtime_probe", "unknown"] },
        "fixed_family": { "type": ["string", "null"], "maxLength": 64 },
        "argv_flag_names": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "environment_names": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Z_][A-Z0-9_]*$" }
        },
        "unknown_is_independent": { "const": false }
      }
    },
    "session_sources": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "priority"],
        "properties": {
          "kind": { "enum": ["herdr_agent_session", "hook_payload", "typed_api", "process_environment", "open_file", "jsonl_metadata", "state_database", "bounded_glob"] },
          "priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
          "environment_name": { "type": ["string", "null"], "maxLength": 128 },
          "path_template": { "type": ["string", "null"], "maxLength": 1000 },
          "json_pointer": { "type": ["string", "null"], "maxLength": 512 },
          "requires_cwd_match": { "type": "boolean", "default": true },
          "requires_process_time_match": { "type": "boolean", "default": true }
        }
      }
    },
    "structured_sources": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "priority"],
        "properties": {
          "id": { "$ref": "#/$defs/slug" },
          "kind": { "enum": ["hook", "jsonl", "local_api", "state_database", "herdr_state"] },
          "priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
          "event_selector": { "type": ["string", "null"], "maxLength": 512 },
          "terminal_only": { "type": "boolean", "default": false }
        }
      }
    },
    "screen_rules": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/screen_rule" }
    },
    "composer_rules": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/screen_rule" }
    },
    "deterministic_recoveries": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/recovery_recipe" }
    },
    "planner_recipes": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/planner_recipe" }
    },
    "fixture_paths": {
      "type": "array",
      "maxItems": 64,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "command_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executable", "args", "timeout_seconds", "max_output_bytes"],
      "properties": {
        "executable": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[A-Za-z0-9_./+-]+$" },
        "args": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "maxLength": 512 }
        },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300 },
        "max_output_bytes": { "type": "integer", "minimum": 1, "maximum": 10000000 }
      }
    },
    "screen_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["contains_literal", "not_contains_literal", "line_safe_regex", "bottom_line_contains", "labelled_menu_option"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "screen_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state", "category", "priority", "confidence", "region", "conditions", "requires_stable_samples"],
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "state": { "enum": ["working", "idle", "blocked", "unknown"] },
        "category": { "type": "string", "minLength": 1, "maxLength": 64 },
        "priority": { "type": "integer", "minimum": -1000, "maximum": 1000 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "region": { "enum": ["bottom_2", "bottom_5", "bottom_12", "whole_recent", "detection", "menu_block"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/screen_condition" }
        },
        "requires_stable_samples": { "type": "integer", "minimum": 1, "maximum": 5 },
        "visible_blocker": { "type": "boolean", "default": false },
        "allow_action": { "type": "boolean", "default": false },
        "version_note": { "type": ["string", "null"], "maxLength": 300 }
      }
    },
    "template_precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["target_identity", "process_alive", "composer_empty", "menu_stable", "event_category", "goal_state", "no_human_intervention"] },
        "value": { "type": ["string", "null"], "maxLength": 256 }
      }
    },
    "template_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["WAIT_PARSED_RESET", "WAIT_BACKOFF", "SEND_FIXED_TEXT", "SEND_FIXED_KEYS", "CHECK_AGENT_STATE", "CHECK_GOAL_STATE", "NOTIFY", "HUMAN_REQUIRED"] },
        "text": { "type": ["string", "null"], "maxLength": 512 },
        "keys": {
          "type": "array",
          "maxItems": 16,
          "items": { "enum": ["ENTER", "ESCAPE", "UP", "DOWN", "LEFT", "RIGHT", "TAB", "BACKTAB"] }
        },
        "seconds": { "type": ["integer", "null"], "minimum": 1, "maximum": 86400 }
      }
    },
    "recovery_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "event_categories", "preconditions", "actions", "max_attempts", "cooldown_seconds", "human_on_failure"],
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "event_categories": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "preconditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/template_precondition" }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/template_action" }
        },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "cooldown_seconds": { "type": "integer", "minimum": 0, "maximum": 86400 },
        "human_on_failure": { "type": "boolean" }
      }
    },
    "planner_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "command", "output_mode", "schema_enforced", "requires_isolated_cwd",
        "tools_disabled", "auto_approval_disabled", "provider_family_source", "enabled_by_default"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "command": { "$ref": "#/$defs/command_spec" },
        "output_mode": { "enum": ["json", "jsonl", "text_then_validate"] },
        "schema_enforced": { "type": "boolean" },
        "requires_isolated_cwd": { "const": true },
        "tools_disabled": { "type": "boolean" },
        "auto_approval_disabled": { "type": "boolean" },
        "provider_family_source": { "enum": ["fixed", "cli_args", "config_probe", "runtime_probe", "unknown"] },
        "fixed_provider_family": { "type": ["string", "null"], "maxLength": 64 },
        "enabled_by_default": { "type": "boolean" },
        "unsafe_reason": { "type": ["string", "null"], "maxLength": 500 }
      }
    }
  }
}
