{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watchme.local/schemas/snapshot.schema.json",
  "title": "WatchMe Redacted Recovery Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "created_at",
    "watcher",
    "target",
    "agent",
    "observations",
    "attempts",
    "allowed_actions",
    "redaction"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "snapshot_id": { "$ref": "#/$defs/id" },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "watcher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["watcher_id", "state", "evidence_fingerprint"],
      "properties": {
        "watcher_id": { "$ref": "#/$defs/id" },
        "state": {
          "enum": [
            "DISCOVERING", "OBSERVING", "SUSPECT", "CONFIRMED_BLOCKED", "WAITING",
            "PLANNING", "ACTING", "VERIFYING", "ESCALATING", "HUMAN_REQUIRED",
            "PAUSED", "TERMINATED"
          ]
        },
        "evidence_fingerprint": { "$ref": "#/$defs/hash" },
        "attempt_budget_remaining": { "type": "integer", "minimum": 0 },
        "planner_budget_remaining": { "type": "integer", "minimum": 0 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mux_kind", "pane_id", "process_pid", "process_start_time", "identity_hash"],
      "properties": {
        "mux_kind": { "enum": ["herdr", "tmux", "direct", "test"] },
        "mux_server_id": { "type": ["string", "null"], "maxLength": 512 },
        "workspace_or_session": { "type": ["string", "null"], "maxLength": 256 },
        "window_or_tab": { "type": ["string", "null"], "maxLength": 256 },
        "pane_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "pane_title": { "type": ["string", "null"], "maxLength": 256 },
        "tty": { "type": ["string", "null"], "maxLength": 256 },
        "process_pid": { "type": "integer", "minimum": 1 },
        "process_start_time": { "type": "string", "minLength": 1, "maxLength": 128 },
        "process_name": { "type": ["string", "null"], "maxLength": 128 },
        "process_argv_redacted": { "type": ["string", "null"], "maxLength": 1000 },
        "identity_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "provider_family", "failed_provider_family"],
      "properties": {
        "agent_id": { "type": ["string", "null"], "maxLength": 64 },
        "agent_version": { "type": ["string", "null"], "maxLength": 128 },
        "session_id": { "type": ["string", "null"], "maxLength": 256 },
        "session_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "provider_family": { "type": ["string", "null"], "maxLength": 64 },
        "model": { "type": ["string", "null"], "maxLength": 256 },
        "failed_provider_family": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "terminal": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "line_count", "text", "truncated"],
          "properties": {
            "source": { "enum": ["detection", "recent", "recent_unwrapped", "visible"] },
            "line_count": { "type": "integer", "minimum": 0, "maximum": 300 },
            "text": { "type": "string", "maxLength": 30000 },
            "truncated": { "type": "boolean" },
            "ansi_removed": { "type": "boolean" },
            "control_sequences_removed": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id", "category", "source_kind", "confidence", "summary", "observed_at"],
        "properties": {
          "event_id": { "$ref": "#/$defs/id" },
          "category": { "type": "string", "minLength": 1, "maxLength": 64 },
          "source_kind": { "type": "string", "minLength": 1, "maxLength": 64 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "observed_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "structured_records": {
      "type": "array",
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "summary"],
        "properties": {
          "source": { "type": "string", "minLength": 1, "maxLength": 256 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      }
    },
    "attempts": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attempt_id", "kind", "result", "at"],
        "properties": {
          "attempt_id": { "$ref": "#/$defs/id" },
          "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
          "result": { "type": "string", "minLength": 1, "maxLength": 500 },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "WAIT_UNTIL", "WAIT_DURATION", "CAPTURE", "CHECK_STATUS", "SEND_TEXT", "SUBMIT_TEXT",
          "SEND_KEYS", "NOTIFY", "ESCALATE", "STOP_WATCHING", "NOOP"
        ]
      }
    },
    "hard_prohibitions": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["performed", "replacement_count", "categories", "raw_evidence_included"],
      "properties": {
        "performed": { "const": true },
        "replacement_count": { "type": "integer", "minimum": 0 },
        "categories": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "raw_evidence_included": { "const": false }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "hash": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Fa-f0-9]+$"
    }
  }
}
