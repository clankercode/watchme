{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watchme.local/schemas/recovery-plan.schema.json",
  "title": "WatchMe Recovery Plan",
  "description": "A bounded proposal from an alternate-provider planner. Validation is necessary but not sufficient; compiled policy must independently authorize every action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "generated_at",
    "valid_until",
    "target",
    "diagnosis",
    "actions"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "plan_id": { "$ref": "#/$defs/id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "valid_until": { "type": "string", "format": "date-time" },
    "target": { "$ref": "#/$defs/target" },
    "diagnosis": { "$ref": "#/$defs/diagnosis" },
    "actions": {
      "type": "array",
      "minItems": 0,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/action" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "bounded_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "provider_family": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "watcher_id",
        "process_pid",
        "process_start_time",
        "mux_kind",
        "pane_id",
        "evidence_fingerprint"
      ],
      "properties": {
        "watcher_id": { "$ref": "#/$defs/id" },
        "process_pid": { "type": "integer", "minimum": 1 },
        "process_start_time": { "type": "string", "minLength": 1, "maxLength": 128 },
        "mux_kind": { "enum": ["herdr", "tmux", "direct", "test"] },
        "mux_server_id": { "type": ["string", "null"], "maxLength": 512 },
        "pane_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "agent_id": { "type": ["string", "null"], "maxLength": 64 },
        "session_id": { "type": ["string", "null"], "maxLength": 256 },
        "evidence_fingerprint": {
          "type": "string",
          "minLength": 16,
          "maxLength": 128,
          "pattern": "^[A-Fa-f0-9]+$"
        }
      }
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "confidence",
        "summary",
        "failed_provider_family",
        "planner_provider_family",
        "human_required"
      ],
      "properties": {
        "category": {
          "enum": [
            "working",
            "idle",
            "usage_limit",
            "session_limit",
            "weekly_limit",
            "transient_overload",
            "capacity_block",
            "paused_goal",
            "blocked_goal",
            "permission_prompt",
            "question_prompt",
            "authentication_failure",
            "billing_failure",
            "model_credit_exhausted",
            "invalid_request",
            "model_unavailable",
            "safety_block",
            "context_limit",
            "terminal_failure",
            "unknown_blocked",
            "no_action"
          ]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "summary": { "$ref": "#/$defs/bounded_text" },
        "failed_provider_family": { "$ref": "#/$defs/provider_family" },
        "planner_provider_family": { "$ref": "#/$defs/provider_family" },
        "human_required": { "type": "boolean" },
        "uncertainties": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        }
      }
    },
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "TARGET_IDENTITY_MATCHES",
            "PROCESS_ALIVE",
            "SESSION_ID_MATCHES",
            "EVIDENCE_FINGERPRINT_MATCHES",
            "COMPOSER_EMPTY",
            "MENU_STABLE",
            "AGENT_STATE_IS",
            "GOAL_STATE_IS",
            "EVENT_CATEGORY_IS",
            "NO_HUMAN_INTERVENTION",
            "CURRENT_TIME_AT_OR_AFTER"
          ]
        },
        "value": {
          "type": ["string", "number", "boolean", "null"],
          "maxLength": 256
        }
      }
    },
    "expected_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "AGENT_WORKING",
            "AGENT_IDLE",
            "BLOCK_CLEARED",
            "GOAL_ACTIVE_OR_PURSUING",
            "MENU_DISMISSED",
            "WAIT_STATE_RECORDED",
            "PROCESS_TERMINATED",
            "HUMAN_NOTIFIED",
            "NO_STATE_CHANGE_EXPECTED"
          ]
        },
        "value": {
          "type": ["string", "number", "boolean", "null"],
          "maxLength": 256
        }
      }
    },
    "common_action_fields": {
      "type": "object",
      "required": ["action_id", "reason", "preconditions", "expected_outcomes", "timeout_seconds"],
      "properties": {
        "action_id": { "$ref": "#/$defs/id" },
        "reason": { "$ref": "#/$defs/reason" },
        "preconditions": {
          "type": "array",
          "maxItems": 12,
          "items": { "$ref": "#/$defs/precondition" }
        },
        "expected_outcomes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/expected_outcome" }
        },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
      }
    },
    "wait_until_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "at"],
          "properties": {
            "type": { "const": "WAIT_UNTIL" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "at": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "wait_duration_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "duration_seconds"],
          "properties": {
            "type": { "const": "WAIT_DURATION" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "duration_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
          }
        }
      ]
    },
    "capture_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "source", "max_lines"],
          "properties": {
            "type": { "const": "CAPTURE" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "source": { "enum": ["screen_detection", "screen_recent", "structured_state", "log_tail"] },
            "max_lines": { "type": "integer", "minimum": 1, "maximum": 300 }
          }
        }
      ]
    },
    "check_status_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "check"],
          "properties": {
            "type": { "const": "CHECK_STATUS" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "check": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": {
                  "enum": [
                    "PROCESS_ALIVE",
                    "TARGET_IDENTITY",
                    "AGENT_STATE",
                    "GOAL_STATE",
                    "EVENT_CLEARED",
                    "COMPOSER_EMPTY",
                    "SCREEN_CONTAINS_LITERAL",
                    "SCREEN_NOT_CONTAINS_LITERAL"
                  ]
                },
                "value": { "type": ["string", "null"], "maxLength": 256 }
              }
            }
          }
        }
      ]
    },
    "send_text_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "SEND_TEXT" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "text": { "type": "string", "minLength": 1, "maxLength": 512 }
          }
        }
      ]
    },
    "send_keys_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "keys"],
          "properties": {
            "type": { "const": "SEND_KEYS" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "keys": {
              "type": "array",
              "minItems": 1,
              "maxItems": 16,
              "items": {
                "enum": [
                  "ENTER", "ESCAPE", "UP", "DOWN", "LEFT", "RIGHT", "TAB", "BACKTAB",
                  "CTRL_C", "CTRL_D", "CTRL_L", "HOME", "END", "PAGE_UP", "PAGE_DOWN"
                ]
              }
            }
          }
        }
      ]
    },
    "notify_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "severity", "message"],
          "properties": {
            "type": { "const": "NOTIFY" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "severity": { "enum": ["info", "warning", "error", "critical"] },
            "message": { "type": "string", "minLength": 1, "maxLength": 500 }
          }
        }
      ]
    },
    "escalate_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "level"],
          "properties": {
            "type": { "const": "ESCALATE" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "level": { "enum": ["alternate_planner", "independent_second_opinion", "human_required"] }
          }
        }
      ]
    },
    "stop_watching_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "STOP_WATCHING" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
          }
        }
      ]
    },
    "noop_action": {
      "allOf": [
        { "$ref": "#/$defs/common_action_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "NOOP" },
            "action_id": { "$ref": "#/$defs/id" },
            "reason": { "$ref": "#/$defs/reason" },
            "preconditions": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/precondition" } },
            "expected_outcomes": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/expected_outcome" } },
            "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
          }
        }
      ]
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/wait_until_action" },
        { "$ref": "#/$defs/wait_duration_action" },
        { "$ref": "#/$defs/capture_action" },
        { "$ref": "#/$defs/check_status_action" },
        { "$ref": "#/$defs/send_text_action" },
        { "$ref": "#/$defs/send_keys_action" },
        { "$ref": "#/$defs/notify_action" },
        { "$ref": "#/$defs/escalate_action" },
        { "$ref": "#/$defs/stop_watching_action" },
        { "$ref": "#/$defs/noop_action" }
      ]
    }
  }
}
